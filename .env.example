# Ambient temperature configuration for heater chart
# Requires enable_temp="yes" in switch.sh and the log_temp.sh cron job running.
# Copy this file to .env and uncomment ONE of the options below.

# Option A: airport ICAO code (recommended for hangar use)
# On first cron run, LATITUDE and LONGITUDE will be automatically appended
# below after geocoding. Delete those two lines to re-geocode.
# LOCATION=KLMO

# Option B: set coordinates directly
# LATITUDE=45.5051
# LONGITUDE=-122.6750
